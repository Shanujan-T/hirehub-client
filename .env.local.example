# HireHub client → API connection
#
# Option A (recommended local dev): Next.js proxy — no CORS issues
# Leave NEXT_PUBLIC_API_URL empty; axios calls same-origin /api/* and /uploads/*
# Next.js rewrites those to HIREHUB_API_URL (Flask).
NEXT_PUBLIC_API_URL=
HIREHUB_API_URL=http://127.0.0.1:5000

# Option B (direct): browser calls Flask directly (requires CORS_ORIGINS on API)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
# HIREHUB_API_URL=http://127.0.0.1:5000
