# HireHub client → API connection (local development)
#
# Direct mode: browser calls Flask on port 5000 (requires CORS_ORIGINS on API).
# Restart `npm run dev` after changing this file.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
# HIREHUB_API_URL=http://127.0.0.1:5000

# Option A (proxy): leave NEXT_PUBLIC_API_URL empty; set HIREHUB_API_URL only.
# NEXT_PUBLIC_API_URL=
# HIREHUB_API_URL=http://127.0.0.1:5000

# Production (Railway) — only when intentionally targeting deployed API:
NEXT_PUBLIC_API_URL=
HIREHUB_API_URL=
