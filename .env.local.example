# HireHub client → API connection
#
# Option A (recommended local dev): use Next.js proxy — no CORS issues
# Leave NEXT_PUBLIC_API_URL empty; set HIREHUB_API_URL to where Flask runs.
NEXT_PUBLIC_API_URL=
HIREHUB_API_URL=http://127.0.0.1:5000

# Option B (direct): call Flask from the browser (requires CORS on API)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
