# HireHub client → API connection
#
# Local development — point at Flask on port 5000 (restart npm run dev after edits):
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
HIREHUB_API_URL=http://127.0.0.1:5000
#
# Option A (proxy): Next.js rewrites same-origin /api/* to Flask — no CORS needed.
# NEXT_PUBLIC_API_URL=
# HIREHUB_API_URL=http://127.0.0.1:5000
#
# Option B (direct): browser calls Flask directly (requires CORS_ORIGINS on API).
# Same values as above with NEXT_PUBLIC_API_URL set.
